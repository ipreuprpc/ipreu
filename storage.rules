rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Simplified checks for Storage to reduce cross-service lookup billing
    // We rely on the frontend rejecting uploads, and only authenticated users can upload.
    // If strict cross-service lookup is enabled, we use firestore.get()
    
    match /announcements/{imageId} {
      allow read: if isMemberOrAdmin();
      allow write: if isAdmin() && request.resource.size < 10 * 1024 * 1024;
    }

    match /profile_photos/{userId} {
      // Profile photos are public for the dashboard/landing page celebratory features
      allow read: if true;
      // Allow users to upload their own photo during registration or profile update
      allow write: if request.auth != null && 
                    request.resource.size < 2 * 1024 * 1024 &&
                    request.resource.contentType.matches('image/.*');
    }

    function isAdmin() {
      return request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isMemberOrAdmin() {
      return request.auth != null && 
             (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'MEMBER' || 
              firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN');
    }
  }
}
