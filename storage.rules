rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Simplified checks for Storage to reduce cross-service lookup billing
    // We rely on the frontend rejecting uploads, and only authenticated users can upload.
    // If strict cross-service lookup is enabled, we use firestore.get()
    
    match /announcements/{imageId} {
      // Anyone signed in can read attachments
      allow read: if request.auth != null;
      // Anyone signed in can write files under 6MB (but only Admins have UI controls)
      allow write: if request.auth != null && request.resource.size < 6 * 1024 * 1024;
    }
  }
}
