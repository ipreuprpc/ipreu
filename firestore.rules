rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }
    
    function isMemberOrAdmin() {
      return request.auth != null && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'MEMBER' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN');
    }

    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.role == 'PENDING' && request.resource.data.keys().hasAll(['email', 'employeeName', 'employeeNumber']);
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isMemberOrAdmin();
      allow write: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if isMemberOrAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isMemberOrAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']));
    }
  }
}
